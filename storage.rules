rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Publicly readable media/assets (legacy: 'products/')
    match /media/{allPaths=**} {
      allow read;
    }
    match /objects/{allPaths=**} {
      allow read;
    }
    match /products/{allPaths=**} {
      allow read;
    }
    match /models/{allPaths=**} {
      allow read;
    }
    
    // Writing is restricted to admins (uploads are usually done via server APIs).
    match /{allPaths=**} {
        allow write: if isAdmin();
    }
  }
}
