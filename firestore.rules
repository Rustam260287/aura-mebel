rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Products can be read by anyone, but only written by authenticated users (admins).
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Blog posts can be read by anyone, but only written by authenticated users (admins).
    match /blog/{postId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // User-specific data (like carts, wishlists) should be protected.
    // This is a placeholder - you would refine this based on your user data structure.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
