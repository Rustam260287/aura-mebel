rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Objects: publicly readable, admin-only writes.
    match /objects/{objectId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Legacy: allow reads from old collection while migrating.
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Journal entries (editorial content)
    match /blog/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Visitor journey analytics: admin-only.
    match /visitors/{visitorId} {
      allow read, write: if isAdmin();
    }
    match /journeyEvents/{eventId} {
      allow read, write: if isAdmin();
    }

    // Settings, jobs, and everything else: admin-only.
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
