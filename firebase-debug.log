[debug] [2025-11-18T09:25:59.669Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/aura-mebel-7ec96/rulesets {"name":"projects/aura-mebel-7ec96/rulesets/7deb82a2-9d6a-4670-86a9-67d5d5010b0b","source":{"files":[{"content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Products can be read by anyone, but only written by authenticated users (admins).\n    match /products/{productId} {\n      allow read: if true;\n      allow write: if request.auth != null;\n    }\n\n    // Blog posts can be read by anyone, but only written by authenticated users (admins).\n    match /blog/{postId} {\n      allow read: if true;\n      allow write: if request.auth != null;\n    }\n\n    // User-specific data (like carts, wishlists) should be protected.\n    // This is a placeholder - you would refine this based on your user data structure.\n    match /users/{userId}/{document=**} {\n      allow read, write: if request.auth != null && request.auth.uid == userId;\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2025-11-18T09:25:59.591695Z","metadata":{"services":["cloud.firestore"]}}
