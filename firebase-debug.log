[debug] [2025-12-17T21:32:17.691Z] <<< [apiv2][body] POST https://firestore.googleapis.com/v1/projects/aura-mebel-7ec96/databases/(default)/documents:batchGet [{"found":{"name":"projects/aura-mebel-7ec96/databases/(default)/documents/products/K76YLoU4Co4T4RkF9xJG","fields":{"name":{"stringValue":"Gucci"},"category":{"stringValue":"Мягкая мебель"},"originalUrl":{"stringValue":"https://label-com.ru/katalog/myagkaya-mebel/gucci-detail.html"},"createdAt":{"stringValue":"2025-12-04T15:54:19.734Z"},"rating":{"integerValue":"0"},"reviews":{"arrayValue":{}},"details":{"mapValue":{"fields":{"dimensions":{"stringValue":""},"material":{"stringValue":""},"care":{"stringValue":""}}}},"price":{"integerValue":"178200"},"seoDescription":{"stringValue":"Диван Gucci представляет собой идеальное сочетание элегантного дизайна и высококачественных материалов, что делает его отличным выбором для создания стильного и уютного интерьера. С откидной спинкой и премиальным стилем этот диван обеспечивает не только комфорт, но и визуальную привлекательность. Габариты дивана составляют 235 см в длину и 93 см в высоту спинки, что позволяет ему гармонично вписываться в различные пространства. Съёмные чехлы добавляют практичности, а тщательный выбор материалов гарантирует долговечность и устойчивость к износу. Диван Gucci — это не просто мебель, это акцент вашего дома."},"bullets":{"arrayValue":{"values":[{"stringValue":"Премиальный стиль, который дополнит любой интерьер."},{"stringValue":"Откидная спинка для дополнительного комфорта."},{"stringValue":"Габариты: длина 235 см, высота спинки 93 см."},{"stringValue":"Высококачественные материалы и конструкция."},{"stringValue":"Съёмные чехлы для удобства ухода."}]}},"embedding":{"arrayValue":{"values":[{"doubleValue":0.008012907579541206},{"doubleValue":0.010153689421713352},{"doubleValue":-0.08589022606611252},{"doubleValue":0.02271171286702156},{"doubleValue":0.014342780224978924},{"doubleValue":-0.05163770541548729},{"doubleValue":-0.046126231551170